# Copy to .env (gitignored). NEVER commit real secrets. TESTNET wallet only.

# --- Phase 1: benchmark scores ---
# Artificial Analysis Data API key (free tier 1000 req/day): https://artificialanalysis.ai/
AA_API_KEY=

# --- Phase A: real x402 payment (Base Sepolia TESTNET) ---
# X402_MODE: mock (default, offline) | real (on-chain testnet payment)
X402_MODE=mock

# TESTNET private key ONLY. Fund the address at https://faucet.circle.com (Base Sepolia USDC).
# Never a mainnet key. Lives only here (.env is gitignored).
WALLET_PRIVATE_KEY=

# v2 network identifier is CAIP-2, NOT the legacy "base-sepolia" string.
X402_NETWORK=eip155:84532
# Base Sepolia USDC contract (6 decimals), for reference:
#   0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Facilitator. Default public testnet facilitator needs NO auth — a funded wallet is enough.
X402_FACILITATOR_URL=https://x402.org/facilitator
# Seller proxy receiving address (where buyers' USDC lands). Required to run seller_proxy.real.
X402_PAY_TO=
PROXY_PRICE=$0.02

# Optional: Coinbase CDP hosted facilitator instead of the public one (needs cdp-sdk wiring).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Spending guardrails (USDC). Agent refuses to pay above these.
MAX_USDC_PER_CALL=0.10
MAX_USDC_PER_SESSION=1.00

# --- Phase 5: frontier backends behind self-built proxy (final test only) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Proxy backend selector: ollama | openrouter_free | anthropic | openai
PROXY_BACKEND=openrouter_free
OPENROUTER_API_KEY=
