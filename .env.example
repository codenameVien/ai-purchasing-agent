# Copy to .env (gitignored). NEVER commit real secrets. TESTNET wallet only.

# --- Phase 1: benchmark scores ---
# Artificial Analysis Data API key (free tier 1000 req/day): https://artificialanalysis.ai/
AA_API_KEY=

# --- Phase 2+: x402 payment (Base Sepolia TESTNET) ---
# Ephemeral testnet private key ONLY. Fund with Base Sepolia USDC faucet. Never a mainnet key.
WALLET_PRIVATE_KEY=
X402_CHAIN=base-sepolia
# Facilitator URL (Coinbase CDP testnet or Heurist). Verify at build time.
X402_FACILITATOR_URL=

# Spending guardrails (USDC). Agent refuses to pay above these.
MAX_USDC_PER_CALL=0.10
MAX_USDC_PER_SESSION=1.00

# --- Phase 5: frontier backends behind self-built proxy (final test only) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Proxy backend selector: ollama | openrouter_free | anthropic | openai
PROXY_BACKEND=openrouter_free
OPENROUTER_API_KEY=
